{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=caseItau.db"
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "CaseItau.API",
    "Audience": "CaseItau.Client",
    "ExpirationHours": "8"
  },
  "Auth": {
    "Username": "",
    "Password": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/caseItau-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
